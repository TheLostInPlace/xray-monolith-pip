	server_objects_registry[obj.id] = nil
end

-- If this is called, Lua called an exported LuaBind method that will result in engine getting a fatal error, leading to semibroken Lua state, ie. "Busy Hands" 
AddScriptCallback("on_luabind_fatal_error")
local LuaFatalErrorUIInstance = nil
local on_luabind_fatal_error_triggered = false
local in_main_menu = false
_G.COnLuaBindFatalError = function(offender)
	-- Don't engage when actor is gone, it doesn't matter at this point
	-- The engine would still log the error
	if not db.actor then
		return
	end

	if in_main_menu then
		return
	end

	if on_luabind_fatal_error_triggered then
		return
	end
	on_luabind_fatal_error_triggered = true

	SendScriptCallback("on_luabind_fatal_error", offender)
	exec_console_cmd("save " .. (user_name() or "") .. " - tempsave")

	LuaFatalErrorUIInstance = LuaFatalErrorUI(offender)
	LuaFatalErrorUIInstance:Show()
end

class "LuaFatalErrorUI" (CUIScriptWnd)
function LuaFatalErrorUI:__init(offender) super()
	self:SetWndRect(Frect():set(0,0,1024,768))
	self:SetAutoDelete(true)

	self.message_box = CUIMessageBoxEx()
	self.offender = offender:gsub("%d.*(%[Lua%] ).*[/\\]", "%1")
	self:Register(self.message_box, "LuaFatalErrorUI_msg_box")

	self:InitCallBacks()
	self:InitControls()
	self:AllowWorkInPause(true)
	self:AllowMovement(true)
	self:AllowCursor(true)

	self.message_box:AllowWorkInPause(true)
	self.message_box:AllowMovement(true)
	self.message_box:AllowCursor(true)

	device():pause(true)
end

function LuaFatalErrorUI:__finalize()
end

function LuaFatalErrorUI:InitCallBacks()
	self:AddCallback("LuaFatalErrorUI_msg_box", ui_events.MESSAGE_BOX_COPY_CLICKED, self.OnMsgCopy, self)
	self:AddCallback("LuaFatalErrorUI_msg_box", ui_events.MESSAGE_BOX_YES_CLICKED, self.OnMsgYes, self)
	self:AddCallback("LuaFatalErrorUI_msg_box", ui_events.MESSAGE_BOX_NO_CLICKED, self.OnMsgNo, self)
end

function LuaFatalErrorUI:InitControls()
	self.message_box:InitMessageBox("message_box_lua_fatal_error")

	local msg_str = game.translate_string("st_lua_fatal_error")
	msg_str = msg_str:gsub("(%[Lua%] ).*[/\\]", "%1")
	local str = strformat(msg_str, self.offender)
	self.message_box:SetText(str)
end

function LuaFatalErrorUI:Show()
    self.message_box:ShowDialog(true)
end

function LuaFatalErrorUI:OnMsgCopy()
	device():pause(false)
	exec_console_cmd("disconnect")
end

function LuaFatalErrorUI:OnMsgYes()
	device():pause(false)
    exec_console_cmd("load " .. (user_name() or "") .. " - tempsave")
end

function LuaFatalErrorUI:OnMsgNo()
	device():pause(false)
end

function main_menu_on_init()
	in_main_menu = true
end

function main_menu_on_quit()
	in_main_menu = false
end

-- Orleon
AddScriptCallback("actor_on_item_sell")
AddScriptCallback("actor_on_item_buy")

function on_game_start()
	RegisterScriptCallback("main_menu_on_init", main_menu_on_init)
	RegisterScriptCallback("main_menu_on_quit", main_menu_on_quit)
	RegisterScriptCallback("actor_on_first_update", actor_on_first_update)
	RegisterScriptCallback("ActorMenu_on_item_after_move", ActorMenu_on_item_after_move)
	RegisterScriptCallback("game_object_on_net_spawn", game_object_on_net_spawn)
	RegisterScriptCallback("game_object_on_net_destroy", game_object_on_net_destroy)
	RegisterScriptCallback("server_object_on_register", server_object_on_register)
	RegisterScriptCallback("server_object_on_unregister", server_object_on_unregister)

	-- Orleon, patch later for compatibility
	ui_inventory_UIInventory_TMode_Sell = ui_inventory.UIInventory.TMode_Sell
	ui_inventory.UIInventory.TMode_Sell = function(self)
	    self.on_sell_callback_flag = true
	    ui_inventory_UIInventory_TMode_Sell(self)
	    self.on_sell_callback_flag = false
	end

	ui_inventory_UIInventory_TMode_Buy = ui_inventory.UIInventory.TMode_Buy
	ui_inventory.UIInventory.TMode_Buy = function(self)
	    self.on_buy_callback_flag = true
	    ui_inventory_UIInventory_TMode_Buy(self)
	    self.on_buy_callback_flag = false
	end

	ui_inventory_UIInventory_On_Item_Exchange = ui_inventory.UIInventory.On_Item_Exchange
	ui_inventory.UIInventory.On_Item_Exchange = function(self, npc_from, npc_to, obj)
	    if self.on_sell_callback_flag then
	        local cc = self.CC["actor_trade"]
	        if cc then
	            local sell_cost = utils_item.get_item_cost(obj, cc.trade_profile)
	            SendScriptCallback("actor_on_item_sell", obj, sell_cost, npc_to)
	        end
	    end
	    if self.on_buy_callback_flag then
	        local cc = self.CC["npc_trade"]
	        if cc then
	            local buy_cost = utils_item.get_item_cost(obj, cc.trade_profile)
	            SendScriptCallback("actor_on_item_buy", obj, buy_cost, npc_from)
	        end
	    end
	    ui_inventory_UIInventory_On_Item_Exchange(self, npc_from, npc_to, obj)
	end
end
